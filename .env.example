DISCORD_WEBHOOK_URL=
LLM_API_KEY=
DISCORD_ROLE_ID=
# LLM_PROVIDER: gemini (default) or claude
LLM_PROVIDER=gemini
# LLM_MODEL: leave blank for the provider default
#   gemini -> gemini-2.0-flash | claude -> claude-haiku-4-5
LLM_MODEL=
SEEN_PATH=.state/seen.json
DRY_RUN=
# Tracker Sheet (optional): set both to mirror matches into a Google Sheet and
# enable the daily reminder pass. In CI these come from secrets, not this file.
GOOGLE_SHEET_ID=
GOOGLE_CREDENTIALS_PATH=google-creds.json
